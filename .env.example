# ─── AWS Bedrock Auth (use EITHER Method 1 or Method 2) ──────────────────────

# Method 1: AWS IAM (standard AWS SDK access keys)
# Key ID starts with AKIA... or ASIA...
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# AWS_REGION=ap-south-1
# AWS_BEDROCK_MODEL=qwen.qwen3-vl-235b-a22b

# Method 2: Custom API proxy/endpoint with Bearer token
# AWS_BEARTER_TOKEN_BEDROCK=
# AWS_BEDROCK_ENDPOINT=https://your-proxy-url.com/model/invoke
