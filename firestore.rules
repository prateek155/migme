rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admins collection - read only for authenticated users
    match /admins/{adminId} {
      allow read: if request.auth != null;
      allow write: if false; // Only backend can create admins
    }

    // Clients collection - authenticated users can read/write their own data
    match /clients/{clientId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Orders - authenticated users can manage
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Menu Items - authenticated users can manage
    match /menuItems/{itemId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Categories - authenticated users can manage
    match /categories/{categoryId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Delivery Executives - authenticated users can manage
    match /executives/{execId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Processed Emails - backend only
    match /processed_emails/{emailId} {
      allow read: if request.auth != null;
      allow write: if false; // Only backend can write
    }
  }
}
